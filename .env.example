# Keepalive-MCP environment — copy to /etc/keepalive-mcp/keepalive-mcp.env
# chmod 640, owned by the service user

# ── database ──────────────────────────────────────────────────────────
KA_DB_DSN=postgresql://keepalive:REPLACE_ME@<db-host>:5432/keepalive

# ── SSH device auth ───────────────────────────────────────────────────
# The pool authenticates to EVERY device with a shared service-account credential
# (the per-device username lives in the DB). Provide a password (TACACS/RADIUS or a
# local account), a private key, or both — at least one is REQUIRED or the server
# refuses to start.
KA_SSH_PASSWORD=REPLACE_ME
# Enable/privilege-escalation password — only if devices require `enable` post-login:
# KA_SSH_SECONDARY=REPLACE_ME
# Default SSH username for admin-onboarded devices (discover_new_device); the shared
# service account, so onboarding only needs name/host/platform.
KA_DEFAULT_USERNAME=REPLACE_ME
# Private key is optional when KA_SSH_PASSWORD is set:
KA_SSH_KEY=/etc/keepalive-mcp/ssh/id_keepalive
KA_SSH_CONFIG=/etc/keepalive-mcp/ssh/ssh_config
# Legacy SSH algorithms for reaching OLD gear. The pool uses asyncssh (pure Python) — NOT
# the system `ssh` / /etc/ssh/ssh_config — so re-enabling weak algs there fixes only the CLI,
# not this server. asyncssh defaults are modern-only; old Cisco gear (banner e.g.
# `SSH-2.0-Cisco-2.0`) fails until you opt legacy algs back in HERE. Values go straight to
# asyncssh.connect() and take the OpenSSH-style +/-/^ prefix; "+" APPENDS to the modern
# defaults, so healthy devices keep negotiating modern algs and only a box offering nothing
# better falls back. Empty = modern-only. Fingerprint a device's KEXINIT offer, then enable
# only what it needs. Real examples seen onboarding IOS-XR PEs:
#   • CBC-only cipher:            KA_SSH_ENCRYPTION_ALGS=+aes256-cbc,aes128-cbc
#   • ancient (group1-sha1 only): KA_SSH_KEX_ALGS=+diffie-hellman-group1-sha1
#                                 KA_SSH_HOSTKEY_ALGS=+ssh-rsa
#                                 KA_SSH_ENCRYPTION_ALGS=+aes256-cbc,aes128-cbc
#                                 KA_SSH_MAC_ALGS=+hmac-sha1
# NOTE: diffie-hellman-group1-sha1 is 1024-bit (weak) — enable ONLY because some boxes offer
# nothing stronger; "+" keeps it last-resort. Prefer group14-sha1 wherever the device allows.
# KA_SSH_KEX_ALGS=
# KA_SSH_HOSTKEY_ALGS=
# KA_SSH_ENCRYPTION_ALGS=
# KA_SSH_MAC_ALGS=

# ── server ────────────────────────────────────────────────────────────
KA_PORT=8784
KA_BIND=127.0.0.1
# Read-only mode: hide the config-push `apply` tool entirely (not just refuse it) and
# tell the LLM only read commands work. Set true when the deployment / SSH account is
# read-only. run still refuses writes regardless. In read-only mode claim_session/
# release_session also drop to the Keepalive.Read tier (a dedicated session grants no
# write power) so read workflows needing connection affinity — e.g. ASA `changeto` — work.
KA_READONLY=false
# Allow full-config / tech-support reads (show running-config, show tech-support). Off by
# default — they're the dense secret source and redaction is imperfect on a full config.
# Output is secret-redacted regardless; raw key/file reads stay blocked either way.
KA_ALLOW_CONFIG_READ=false
# Output handling. Command output up to KA_MAX_OUTPUT_CHARS is returned inline; anything
# larger is captured server-side (RAM only) and paged/grepped via the read_output tool.
KA_MAX_OUTPUT_CHARS=60000
# KA_CAPTURE_TTL_SECS=600     # how long a captured output lives
# KA_CAPTURE_MAX=32           # max concurrent captures held in memory

# ── pool tuning ───────────────────────────────────────────────────────
KA_KEEPALIVE_SECS=30
KA_DEDICATED_TTL_SECS=300
KA_RECONNECT_WAIT_SECS=300

# ── Entra auth ────────────────────────────────────────────────────────
KA_TENANT_ID=<tenant-guid>
KA_CLIENT_ID=<client-guid>
KA_AUDIENCE=https://<public-host>/keepalive
KA_REQUIRED_SCOPE=user_impersonation
# appids allowed to call this API. Include Turnstone (delegated user tokens) AND
# the device-admin CLI's service principal (app-only tokens) if you use kadev —
# the app-only token's appid is gated here too.
KA_ALLOWED_CLIENTS=REPLACE_WITH_TURNSTONE_CLIENT_ID,REPLACE_WITH_KADEV_SP_CLIENT_ID
# Device-pool management (REST /devices add/update/remove, and the kadev CLI)
# requires the Keepalive.Admin app role. Add it to the app registration and grant
# it to the CLI's service principal (application permission + admin consent).
# Admin implies Read+Config. Adding/removing devices needs NO restart — the running
# service reconciles via the Postgres NOTIFY trigger (deploy/migrations/001_*.sql).

# Status-page SSO (interactive browser login). REDIRECT_URI is REQUIRED — the
# server fails closed at startup if it is unset (no baked-in host default).
KA_REDIRECT_URI=https://<public-host>/keepalive/auth/callback
# Only members of this Entra app role may view the status page / JSON.
KA_STATUS_ROLE=Keepalive.Read
# Comma-separated Host: headers the MCP transport will accept (DNS-rebinding guard).
KA_ALLOWED_HOSTS=<public-host>,127.0.0.1:8784
# SSH host-key policy: "strict" verifies every device against KA_SSH_KNOWN_HOSTS
# and refuses unknown/changed keys (server refuses to start if the file is
# missing/empty — seed it once with `ssh-keyscan -f <hosts> > known_hosts`).
# "off" skips verification (MITM-exposed; only for a trusted bootstrap/lab).
KA_SSH_HOSTKEY_POLICY=strict
KA_SSH_KNOWN_HOSTS=/etc/keepalive-mcp/ssh/known_hosts
