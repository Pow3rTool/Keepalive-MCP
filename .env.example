# Keepalive-MCP environment — copy to /etc/keepalive-mcp/keepalive-mcp.env
# chmod 640, owned by the service user

# ── database ──────────────────────────────────────────────────────────
KA_DB_DSN=postgresql://keepalive:REPLACE_ME@<db-host>:5432/keepalive

# ── SSH ───────────────────────────────────────────────────────────────
KA_SSH_KEY=/etc/keepalive-mcp/ssh/id_keepalive
KA_SSH_CONFIG=/etc/keepalive-mcp/ssh/ssh_config

# ── server ────────────────────────────────────────────────────────────
KA_PORT=8784
KA_BIND=127.0.0.1

# ── pool tuning ───────────────────────────────────────────────────────
KA_KEEPALIVE_SECS=30
KA_DEDICATED_TTL_SECS=300
KA_RECONNECT_WAIT_SECS=300

# ── Entra auth ────────────────────────────────────────────────────────
KA_TENANT_ID=<tenant-guid>
KA_CLIENT_ID=<client-guid>
KA_AUDIENCE=https://<public-host>/keepalive
KA_REQUIRED_SCOPE=user_impersonation
# appids allowed to call this API. Include Turnstone (delegated user tokens) AND
# the device-admin CLI's service principal (app-only tokens) if you use kadev —
# the app-only token's appid is gated here too.
KA_ALLOWED_CLIENTS=REPLACE_WITH_TURNSTONE_CLIENT_ID,REPLACE_WITH_KADEV_SP_CLIENT_ID
# Device-pool management (REST /devices add/update/remove, and the kadev CLI)
# requires the Keepalive.Admin app role. Add it to the app registration and grant
# it to the CLI's service principal (application permission + admin consent).
# Admin implies Read+Config. Adding/removing devices needs NO restart — the running
# service reconciles via the Postgres NOTIFY trigger (deploy/migrations/001_*.sql).

# Status-page SSO (interactive browser login). REDIRECT_URI is REQUIRED — the
# server fails closed at startup if it is unset (no baked-in host default).
KA_REDIRECT_URI=https://<public-host>/keepalive/auth/callback
# Only members of this Entra app role may view the status page / JSON.
KA_STATUS_ROLE=Keepalive.Read
# Comma-separated Host: headers the MCP transport will accept (DNS-rebinding guard).
KA_ALLOWED_HOSTS=<public-host>,127.0.0.1:8784
# SSH host-key policy: "strict" verifies every device against KA_SSH_KNOWN_HOSTS
# and refuses unknown/changed keys (server refuses to start if the file is
# missing/empty — seed it once with `ssh-keyscan -f <hosts> > known_hosts`).
# "off" skips verification (MITM-exposed; only for a trusted bootstrap/lab).
KA_SSH_HOSTKEY_POLICY=strict
KA_SSH_KNOWN_HOSTS=/etc/keepalive-mcp/ssh/known_hosts
